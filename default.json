{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>aquaproj/aqua-renovate-config#2.10.0",
    "config:best-practices",
    ":disableRateLimiting",
    ":label(renovate)",
    ":timezone(Asia/Tokyo)"
  ],
  "dependencyDashboard": false,
  "configMigration": true,
  "minimumReleaseAge": "7 days",
  "automerge": true,
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchPackageNames": ["aquaproj/aqua-registry"],
      "extends": ["schedule:earlyMondays"]
    },
    {
      "description": "Major updates - block automerge",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "renovate:major"]
    },
    {
      "description": "Minor updates",
      "matchUpdateTypes": ["minor"],
      "labels": ["renovate", "renovate:minor"]
    },
    {
      "description": "Patch updates",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "labels": ["renovate", "renovate:patch"]
    }
  ]
}
